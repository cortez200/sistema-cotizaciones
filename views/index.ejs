<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doña Alcira - Cotizaciones</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .table-input { border: none; background: transparent; width: 100%; }
        .table-input:focus { outline: none; border-bottom: 2px solid #198754; }
        .header-quote { background-color: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 20px; }
        .total-row { background-color: #e9ecef; font-weight: bold; }
        .card-historial { margin-top: 40px; border-top: 5px solid #0d6efd; }

        /* --- MEJORAS PARA CELULARES (RESPONSIVE) --- */
        @media (max-width: 768px) {
            .card-body { padding: 1.5rem !important; } /* Menos margen en móvil */
            .header-quote h2 { font-size: 1.5rem; text-align: center; }
            .btn-lg { width: 100%; } /* Botón de generar ocupa todo el ancho */
            
            /* Contenedor de tabla con scroll horizontal */
            .table-responsive-mobile {
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                margin-bottom: 1rem;
            }
            
            /* Evita que las celdas de la tabla se compriman demasiado */
            #tabla-items {
                min-width: 700px; 
            }
            
            /* Ajuste de inputs para que sean fáciles de tocar */
            .form-control {
                font-size: 16px; /* Evita zoom automático en iPhone */
                margin-bottom: 10px;
            }
        }
    </style>
</head>
<body class="bg-light">

<div class="container my-3 my-md-5">
    <div class="card shadow border-0">
        <div class="card-body p-3 p-md-5">
            <div class="header-quote">
                <h2 class="text-success fw-bold">GRASS DOÑA ALCIRA</h2>
                <p id="fecha-actual" class="text-muted text-center text-md-start"></p>
                <div class="row mt-4">
                    <div class="col-12 col-md-6">
                        <div class="mb-2"><strong>Señores:</strong> <input type="text" id="cliente" class="form-control"></div>
                        <div class="mb-2"><strong>TELF:</strong> <input type="text" id="telefono" class="form-control"></div>
                        <div class="mb-2"><strong>ATENCION:</strong> <input type="text" id="atencion" class="form-control"></div>
                    </div>
                </div>
            </div>

            <div class="table-responsive-mobile">
                <table class="table table-bordered border-dark mt-4" id="tabla-items">
                    <thead class="table-dark text-center">
                        <tr>
                            <th style="width: 50px;">ITEM</th>
                            <th style="width: 80px;">U.M.</th>
                            <th style="width: 100px;">CANT.</th>
                            <th>DESCRIPCION</th>
                            <th style="width: 150px;">V. VENTA</th>
                            <th style="width: 50px;"></th>
                        </tr>
                    </thead>
                    <tbody id="cuerpo-tabla"></tbody>
                    <tfoot>
                        <tr>
                            <td colspan="4" class="text-end fw-bold">VALOR DE VENTA S/:</td>
                            <td id="valor-venta" class="text-center">0.00</td>
                            <td></td>
                        </tr>
                        <tr>
                            <td colspan="4" class="text-end fw-bold">IGV (18%) S/:</td>
                            <td id="igv-total" class="text-center">0.00</td>
                            <td></td>
                        </tr>
                        <tr class="total-row">
                            <td colspan="4" class="text-end fw-bold fs-5">TOTAL S/:</td>
                            <td id="total-final" class="text-center fs-5 text-success">0.00</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <button type="button" class="btn btn-outline-success btn-sm mb-4 w-100 w-md-auto" onclick="agregarFila()">
                <i class="bi bi-plus-circle"></i> Agregar Ítem
            </button>

            <div class="text-center">
                <button type="button" onclick="guardarCotizacion()" class="btn btn-primary btn-lg shadow px-5">
                    <i class="bi bi-file-earmark-pdf-fill"></i> GENERAR Y GUARDAR
                </button>
            </div>
        </div>
    </div>

    <div class="card shadow card-historial mb-5">
        <div class="card-header bg-white"><h4 class="mb-0">Historial de Cotizaciones</h4></div>
        <div class="card-body p-2 p-md-3">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Cliente</th>
                            <th class="d-none d-md-table-cell">Fecha</th> <th>Total</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="tabla-historial"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="/js/script.js"></script>
</body>
</html>